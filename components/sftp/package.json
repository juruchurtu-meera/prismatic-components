{
  "name": "@prismatic-io/sftp",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "build": "npm run format && npm run lint && webpack",
    "publish": "npm run build && prism components:publish",
    "generate:manifest": "npm run build && npx @prismatic-io/spectral component-manifest",
    "generate:manifest:dev": "npm run build && npx @prismatic-io/spectral component-manifest --skip-signature-verify",
    "lint": "biome lint .",
    "format": "biome format --write . --indent-style=space",
    "test": "jest --maxWorkers=4"
  },
  "dependencies": {
    "@prismatic-io/spectral": "10.17.1",
    "mime-types": "2.1.35",
    "minimatch": "^9.0.3",
    "ssh2-sftp-client": "9.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/jest": "29.5.14",
    "@types/mime-types": "2.1.4",
    "@types/node": "18.19.111",
    "@types/ssh2-sftp-client": "9.0.4",
    "copy-webpack-plugin": "13.0.0",
    "jest": "29.7.0",
    "node-loader": "2.1.0",
    "ts-jest": "29.3.4",
    "ts-loader": "9.5.2",
    "typescript": "5.8.3",
    "webpack": "5.99.9",
    "webpack-cli": "6.0.1"
  }
}
