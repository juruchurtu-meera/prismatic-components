{
  "name": "@prismatic-io/openai",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "build": "npm run format && npm run lint && node esbuild.config.js",
    "test": "vitest",
    "publish": "npm run build && prism components:publish",
    "generate:manifest": "npm run build && npx @prismatic-io/spectral component-manifest",
    "generate:manifest:dev": "npm run build && npx @prismatic-io/spectral component-manifest --skip-signature-verify"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.3",
    "@openai/agents": "^0.0.17",
    "@prismatic-io/spectral": "10.17.1",
    "zod": "<=3.25.67"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/jest": "29.5.14",
    "@types/node": "18.19.3",
    "dotenv": "^16.0.3",
    "esbuild": "^0.25.8",
    "fs-extra": "^11.3.0",
    "jest": "29.7.0",
    "ts-jest": "29.3.2",
    "typescript": "5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4",
    "webpack-cli": "^6.0.1"
  }
}
