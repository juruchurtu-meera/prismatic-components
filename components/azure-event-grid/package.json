{
  "name": "azure-event-grid",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "generate:manifest": "npm run build && npx @prismatic-io/spectral component-manifest",
    "generate:manifest:dev": "npm run build && npx @prismatic-io/spectral component-manifest --skip-signature-verify",
    "test": "jest --maxWorkers=4",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "build": "webpack",
    "publish": "npm run build && prism components:publish"
  },
  "dependencies": {
    "@azure/arm-eventgrid": "^14.1.0",
    "@azure/eventgrid": "^5.8.0",
    "@azure/eventgrid-namespaces": "^1.0.0",
    "@azure/identity": "^4.5.0",
    "@prismatic-io/spectral": "10.17.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@types/jest": "30.0.0",
    "copy-webpack-plugin": "13.0.1",
    "jest": "30.2.0",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "typescript": "5.9.3",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1"
  }
}
