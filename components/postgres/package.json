{
  "name": "@prismatic-io/postgres",
  "private": true,
  "license": "Apache-2.0",
  "version": "0.0.1",
  "main": "index.js",
  "scripts": {
    "lint": "eslint --cache --quiet --ext .ts,.js --ignore-pattern '*fixtures*' .",
    "lint-fix": "eslint --cache --fix --quiet --ext .ts,.js --ignore-pattern '*fixtures*' .",
    "format": "npm run lint-fix && prettier --loglevel error --write \"./src/**/*.{js,jsx,ts,tsx,css,html,json,scss}\" \"documentation/*.mdx\"",
    "check-format": "prettier --check \"./src/**/*.{js,jsx,ts,tsx,css,html,json,scss}\" \"documentation/*.mdx\"",
    "build": "npm run format && npm run lint && webpack",
    "test": "echo 'no tests'",
    "publish": "npm run build && prism components:publish"
  },
  "dependencies": {
    "@prismatic-io/spectral": "10.17.1",
    "lodash.merge": "4.6.2",
    "pg-promise": "11.10.2"
  },
  "devDependencies": {
    "@prismatic-io/eslint-config-spectral": "2.0.1",
    "@types/jest": "29.5.11",
    "@types/lodash.merge": "4.6.9",
    "copy-webpack-plugin": "11.0.0",
    "eslint": "8.57.0",
    "jest": "29.7.0",
    "ts-jest": "29.1.1",
    "ts-loader": "9.2.3",
    "typescript": "5.5.3",
    "webpack": "5.76.3",
    "webpack-cli": "5.0.1"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@prismatic-io/eslint-config-spectral"
    ]
  }
}
