    "firebase-admin": "11.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.5",
    "@types/node": "18.19.129",
    "copy-webpack-plugin": "13.0.1",
    "ts-loader": "9.5.4",
    "typescript": "5.9.3",
    "webpack": "5.102.1",
    "webpack-cli": "6.0.1"
  }
}
