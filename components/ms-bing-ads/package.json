{
  "name": "@prismatic-io/ms-bing-ads",
  "private": true,
  "license": "Apache-2.0",
  "version": "0.0.1",
  "scripts": {
    "lint": "eslint --quiet --ext .ts,.js .",
    "lint-fix": "eslint --fix --quiet --ext .ts,.js .",
    "format": "npm run lint-fix && prettier --log-level error --write \"./src/**/*.{js,jsx,ts,tsx,css,html,json,scss}\" \"documentation/*.mdx\"",
    "check-format": "prettier --check \"./src/**/*.{js,jsx,ts,tsx,css,html,json,scss}\" \"documentation/*.mdx\"",
    "build": "npm run format && npm run lint && webpack",
    "publish": "npm run build && prism components:publish",
    "test": "echo 'no tests'"
  },
  "dependencies": {
    "@prismatic-io/spectral": "10.17.1",
    "lodash": "4.17.21",
    "soap": "0.44.0"
  },
  "devDependencies": {
    "@prismatic-io/eslint-config-spectral": "2.0.2",
    "@types/jest": "29.5.11",
    "@types/json-bigint": "^1.0.4",
    "copy-webpack-plugin": "11.0.0",
    "eslint": "8.57.0",
    "jest": "29.7.0",
    "ts-jest": "29.1.1",
    "ts-loader": "9.2.3",
    "typescript": "5.5.3",
    "webpack": "5.76.3",
    "webpack-cli": "5.0.1",
    "@types/easy-soap-request": "^4.1.1",
    "@types/lodash": "4.14.155",
    "@types/node": "14.14.35"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@prismatic-io/eslint-config-spectral"
    ]
  }
}
