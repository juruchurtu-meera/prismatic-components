{
  "name": "@prismatic-io/monday",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "build": "npm run format && npm run lint && webpack",
    "test": "echo 'no tests'",
    "publish": "npm run build && prism components:publish",
    "generate:manifest": "npm run build && npx @prismatic-io/spectral component-manifest",
    "generate:manifest:dev": "npm run build && npx @prismatic-io/spectral component-manifest --skip-signature-verify"
  },
  "dependencies": {
    "@prismatic-io/spectral": "10.17.1",
    "graphql": "15.8.0",
    "graphql-request": "5.0.0",
    "lodash.merge": "4.6.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/jest": "30.0.0",
    "@types/lodash.merge": "4.6.9",
    "@types/node": "22.19.15",
    "copy-webpack-plugin": "13.0.1",
    "graphql-tag": "^2.12.6",
    "jest": "30.3.0",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "typescript": "5.9.3",
    "webpack": "5.105.4",
    "webpack-cli": "6.0.1"
  }
}
