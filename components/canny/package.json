  "dependencies": {
    "@prismatic-io/spectral": "10.18.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/jest": "30.0.0",
    "@types/node": "^25.6.0",
    "copy-webpack-plugin": "14.0.0",
    "jest": "30.3.0",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.7",
    "typescript": "6.0.3",
    "webpack": "5.106.2",
    "webpack-cli": "7.0.2"
  }
}
