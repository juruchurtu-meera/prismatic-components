{
  "name": "@prismatic-io/aws-ses",
  "private": true,
  "version": "0.0.1",
  "description": "Amazon Simple Email Service Component for Prismatic",
  "main": "index.ts",
  "scripts": {
    "build": "webpack",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "publish": "npm run build && prism components:publish",
    "generate-regions-json": "aws ec2 describe-regions | jq '.Regions | map(.RegionName) | sort' > src/aws-regions.json",
    "test": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "3.1055.0",
    "@prismatic-io/spectral": "10.18.6",
    "aws-utils": "file:../../packages/aws-utils",
    "nodemailer": "6.9.1"
  },
  "author": "Prismatic",
  "license": "Apache-2.0",
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/jest": "29.5.14",
    "@types/node": "18.19.110",
    "copy-webpack-plugin": "13.0.1",
    "jest": "29.7.0",
    "ts-jest": "29.4.11",
    "ts-loader": "9.5.7",
    "typescript": "5.9.3",
    "webpack": "5.107.2",
    "webpack-cli": "6.0.1"
  }
}
