{
  "name": "@prismatic-io/aws-s3",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "build": "npm run format && npm run lint && webpack",
    "publish": "npm run build && prism components:publish",
    "generate-regions-json": "aws ec2 describe-regions | jq '.Regions | map(.RegionName) | sort' > src/aws-regions.json",
    "test": "echo 'no tests'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1055.0",
    "@aws-sdk/client-sns": "3.1055.0",
    "@aws-sdk/client-sts": "3.1055.0",
    "@aws-sdk/lib-storage": "3.1055.0",
    "@aws-sdk/s3-request-presigner": "3.1055.0",
    "@aws-sdk/signature-v4-crt": "3.1055.0",
    "@prismatic-io/spectral": "10.18.6",
    "aws-utils": "file:../../packages/aws-utils",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^18.19.0",
    "copy-webpack-plugin": "^12.0.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4"
  }
}
