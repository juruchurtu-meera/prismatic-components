    "@types/jest": "30.0.0",
    "@types/lodash": "^4.17.9",
    "@types/node": "18.19.130",
    "copy-webpack-plugin": "13.0.1",
    "jest": "30.2.0",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "typescript": "5.9.3",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1"
  }
