  },
  "dependencies": {
    "@prismatic-io/spectral": "10.17.1",
    "googleapis": "^118.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@types/jest": "30.0.0",
    "@types/node": "18.19.130",
    "copy-webpack-plugin": "13.0.1",
    "jest": "30.2.0",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "typescript": "5.9.3",
    "webpack": "5.103.0",
    "webpack-cli": "6.0.1"
  }
}
