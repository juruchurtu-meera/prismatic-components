{
  "name": "@prismatic-io/aws-lambda",
  "private": true,
  "version": "0.0.1",
  "description": "Amazon Lambda Component for Prismatic",
  "main": "index.ts",
  "scripts": {
    "build": "webpack",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "generate-regions-json": "aws ec2 describe-regions | jq '.Regions | map(.RegionName) | sort' > src/aws-regions.json",
    "publish": "npm run build && prism components:publish",
    "test": "echo 'no tests'"
  },
  "dependencies": {
    "aws-utils": "file:../../packages/aws-utils",
    "@aws-sdk/client-lambda": "3.1055.0",
    "@prismatic-io/spectral": "10.18.6"
  },
  "author": "Prismatic",
  "license": "Apache-2.0",
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/jest": "30.0.0",
    "@types/node": "^25.3.0",
    "copy-webpack-plugin": "13.0.1",
    "jest": "30.2.0",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "typescript": "5.9.3",
    "webpack": "5.105.2",
    "webpack-cli": "6.0.1"
  }
}
