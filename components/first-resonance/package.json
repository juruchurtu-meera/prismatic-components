    "lint": "biome lint --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@prismatic-io/spectral": "10.17.1",
    "cross-fetch": "^4.1.0",
    "graphql": "^16.12.0",
    "graphql-request": "^7.4.0",
    "graphql-tag": "^2.12.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@types/node": "^18.19.68",
    "copy-webpack-plugin": "13.0.1",
    "ts-loader": "9.5.4",
    "typescript": "5.9.3",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1"
  }
}
