  "version": "0.0.1",
  "scripts": {
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "build": "npm run format && npm run lint && webpack",
    "publish": "npm run build && prism components:publish",
    "generate:manifest": "npm run build && npx @prismatic-io/spectral component-manifest",
    "generate:manifest:dev": "npm run build && npx @prismatic-io/spectral component-manifest --skip-signature-verify",
    "test": "echo 'no tests'"
  },
  "dependencies": {
    "@prismatic-io/spectral": "10.17.1",
    "jsonwebtoken": "^9.0.2",
    "uid-safe": "^2.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/uid-safe": "^2.1.3",
    "form-data": "^4.0.0",
    "copy-webpack-plugin": "13.0.1",
    "ts-loader": "9.5.4",
    "typescript": "5.9.3",
    "webpack": "5.105.2",
    "webpack-cli": "6.0.1"
  }
}
