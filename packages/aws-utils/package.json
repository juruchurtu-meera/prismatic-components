{
  "name": "aws-utils",
  "private": true,
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "/dist"
  ],
  "scripts": {
    "test": "jest",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "build": "npm run format && npm run lint && tsc",
    "generate-regions-json": "aws ec2 describe-regions | jq '.Regions | map(.RegionName) | sort' > src/data/aws-regions.json"
  },
  "dependencies": {
    "@aws-sdk/client-sts": "3.1055.0",
    "@prismatic-io/spectral": "10.18.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@types/jest": "30.0.0",
    "jest": "30.0.5",
    "ts-jest": "29.4.0",
    "typescript": "5.9.3"
  }
}
